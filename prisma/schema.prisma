generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoomStatus {
  ACTIVE
  DELETED

  @@map("bendy_shadowsend_room_status")
}

enum RoomRole {
  OWNER
  MEMBER

  @@map("bendy_shadowsend_room_role")
}

enum MemberStatus {
  ACTIVE
  PENDING
  KICKED
  LEFT

  @@map("bendy_shadowsend_member_status")
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("bendy_shadowsend_request_status")
}

enum InviteStatus {
  ACTIVE
  USED
  EXPIRED

  @@map("bendy_shadowsend_invite_status")
}

enum MessageType {
  TEXT
  FILE
  MIXED

  @@map("bendy_shadowsend_message_type")
}

enum PreviewType {
  NONE
  IMAGE
  VIDEO

  @@map("bendy_shadowsend_preview_type")
}

enum AttachmentStorage {
  S3
  DUFS

  @@map("bendy_shadowsend_attachment_storage")
}

model User {
  id                 String         @id @default(cuid())
  nickname           String
  avatarInitial      String
  avatarColor        String
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  ownedRooms         Room[]         @relation("RoomOwner")
  memberships        RoomMember[]
  invitedMemberships RoomMember[]   @relation("MembershipInviter")
  sentMessages       Message[]      @relation("MessageSender")
  uploadedAttachments MessageAttachment[] @relation("AttachmentUploader")
  presences          Presence[]
  sentInvites        RoomInvite[]   @relation("InviteSender")
  usedInvites        RoomInvite[]   @relation("InviteUsedBy")
  joinRequests       JoinRequest[]  @relation("RequestApplicant")
  reviewedRequests   JoinRequest[]  @relation("RequestReviewer")

  @@map("bendy_shadowsend_user")
}

model Room {
  id                String       @id @default(cuid())
  roomCode          String       @unique
  name              String
  ownerId           String
  owner             User         @relation("RoomOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  gateCode          String?
  gateCodeExpiresAt DateTime?
  announcementText  String?
  announcementImageKey String?
  announcementImageName String?
  announcementImageStorage AttachmentStorage?
  announcementUpdatedAt DateTime?
  status            RoomStatus   @default(ACTIVE)
  deletedAt         DateTime?
  lastActiveAt      DateTime     @default(now())
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  members           RoomMember[]
  messages          Message[]
  invites           RoomInvite[]
  joinRequests      JoinRequest[]
  attachments       MessageAttachment[]
  presences         Presence[]

  @@index([status, lastActiveAt])
  @@index([ownerId, status])
  @@map("bendy_shadowsend_room")
}

model RoomMember {
  id              String       @id @default(cuid())
  roomId          String
  userId          String
  role            RoomRole     @default(MEMBER)
  status          MemberStatus @default(ACTIVE)
  requiresApproval Boolean     @default(false)
  announcementSeenAt DateTime?
  joinedAt        DateTime?
  kickedAt        DateTime?
  lastSeenAt      DateTime     @default(now())
  invitedById     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  room            Room         @relation(fields: [roomId], references: [id], onDelete: Restrict)
  user            User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  invitedBy       User?        @relation("MembershipInviter", fields: [invitedById], references: [id], onDelete: SetNull)
  requests        JoinRequest[]

  @@unique([roomId, userId])
  @@index([userId, status])
  @@index([roomId, status])
  @@map("bendy_shadowsend_room_member")
}

model JoinRequest {
  id           String        @id @default(cuid())
  roomId       String
  userId       String
  memberId     String?
  status       RequestStatus @default(PENDING)
  reason       String?
  reviewedAt   DateTime?
  reviewedById String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  room         Room          @relation(fields: [roomId], references: [id], onDelete: Restrict)
  user         User          @relation("RequestApplicant", fields: [userId], references: [id], onDelete: Restrict)
  member       RoomMember?   @relation(fields: [memberId], references: [id], onDelete: SetNull)
  reviewedBy   User?         @relation("RequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([roomId, status, createdAt])
  @@index([userId, status])
  @@map("bendy_shadowsend_join_request")
}

model RoomInvite {
  id        String      @id @default(cuid())
  roomId     String
  token      String      @unique
  inviterId  String
  status     InviteStatus @default(ACTIVE)
  expiresAt  DateTime
  usedById   String?
  usedAt     DateTime?
  createdAt  DateTime     @default(now())
  room       Room         @relation(fields: [roomId], references: [id], onDelete: Restrict)
  inviter    User         @relation("InviteSender", fields: [inviterId], references: [id], onDelete: Restrict)
  usedBy     User?        @relation("InviteUsedBy", fields: [usedById], references: [id], onDelete: SetNull)

  @@index([roomId, status, expiresAt])
  @@map("bendy_shadowsend_room_invite")
}

model Message {
  id               String             @id @default(cuid())
  roomId           String
  senderId         String
  type             MessageType        @default(TEXT)
  encryptedContent String?
  createdAt        DateTime           @default(now())
  room             Room               @relation(fields: [roomId], references: [id], onDelete: Restrict)
  sender           User               @relation("MessageSender", fields: [senderId], references: [id], onDelete: Restrict)
  attachments      MessageAttachment[]

  @@index([roomId, createdAt])
  @@map("bendy_shadowsend_message")
}

model MessageAttachment {
  id         String      @id @default(cuid())
  messageId  String
  roomId     String
  uploaderId String
  fileName   String
  mimeType   String
  sizeBytes  Int
  s3Key      String
  storage    AttachmentStorage @default(S3)
  previewType PreviewType @default(NONE)
  createdAt  DateTime     @default(now())
  message    Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  room       Room         @relation(fields: [roomId], references: [id], onDelete: Restrict)
  uploader   User         @relation("AttachmentUploader", fields: [uploaderId], references: [id], onDelete: Restrict)

  @@index([roomId, createdAt])
  @@map("bendy_shadowsend_message_attachment")
}

model Presence {
  id         String   @id @default(cuid())
  userId     String   @unique
  roomId     String?
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  room       Room?    @relation(fields: [roomId], references: [id], onDelete: SetNull)

  @@index([lastSeenAt])
  @@index([roomId, lastSeenAt])
  @@map("bendy_shadowsend_presence")
}

